<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:background="@color/bg">

    <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg"
            app:titleTextColor="@color/textPrimary"
            app:subtitleTextColor="@color/textSecondary"
            app:navigationIcon="@drawable/baseline_arrow_back_24"
            app:navigationIconTint="@color/textPrimary"
            app:title="Match Details"
            app:subtitle="Sunday Kickabout" />

    <ProgressBar
        android:id="@+id/progressBarDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <TextView
                    android:id="@+id/tvDetailsTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Team A vs Team B"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

            <TextView
                    android:id="@+id/tvDetailsDateTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2026-02-01 20:30"
                    android:paddingTop="8dp"
                    android:textColor="@color/textPrimary" />

            <TextView
                    android:id="@+id/tvDetailsLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:paddingTop="4dp"
                    android:textColor="@color/textPrimary" />

            <Button
                android:id="@+id/btnViewLocation"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Stadium GPS / Location"
                android:textColor="@color/primary"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/tvDetailsStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Upcoming"
                android:paddingTop="4dp"
                android:textColor="@color/textPrimary" />

            <TextView
                android:id="@+id/tvDetailsAttendance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 confirmed"
                android:paddingTop="4dp"
                android:textColor="@color/textPrimary" />

            <TextView
                android:id="@+id/tvDetailsCurrentScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Current score: —"
                    android:paddingTop="12dp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Submit Score"
                    android:paddingTop="16dp"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/textPrimary" />
            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enter the final score to mark this football match as completed."
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

            <EditText
                    android:id="@+id/etHomeScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Home team score"
                    android:inputType="number"
                    android:paddingTop="8dp"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textSecondary" />

            <EditText
                    android:id="@+id/etAwayScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Away team score"
                    android:inputType="number"
                    android:paddingTop="8dp"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textSecondary" />

            <Button
                    android:id="@+id/btnSaveScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Score"
                    android:paddingTop="12dp" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>