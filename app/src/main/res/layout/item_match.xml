<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginBottom="12dp"
              android:background="@drawable/bg_card"
              android:padding="14dp"
              android:orientation="vertical">

    <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sun, Jan 28  3:00 PM"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:textSize="14sp"/>

        <TextView
                android:id="@+id/tvPillStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="Upcoming"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:background="@drawable/bg_pill_upcoming"/>
    </RelativeLayout>

    <TextView
            android:id="@+id/tvLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Central Park Field"
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:paddingTop="10dp"/>

    <TextView
            android:id="@+id/tvAttendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3 confirmed · 1 maybe"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:paddingTop="10dp"/>

    <!-- Score box (מופיע רק ב-Completed) -->
    <LinearLayout
            android:id="@+id/scoreBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:background="@color/surface2"
            android:visibility="gone"
            android:orientation="horizontal"
            android:gravity="center">

        <TextView
                android:id="@+id/tvScoreBig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3  -  2"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:textSize="26sp"/>
    </LinearLayout>

</LinearLayout>