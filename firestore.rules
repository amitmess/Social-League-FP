rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /matches/{matchId} {
      // Anyone can read matches (social league requirement)
      allow read: if true;

      // Only authenticated users can update scores or matches
      // Note: In a real app, we might check for specific roles, but as per PRD:
      allow write: if request.auth != null;
    }
  }
}
